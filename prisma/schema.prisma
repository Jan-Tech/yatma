generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYER
}

enum JobStatus {
  PENDING
  ACTIVE
  REJECTED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYER)
  createdAt DateTime @default(now())

  employer Employer?
}

model Employer {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  phone       String?
  whatsapp    String?
  website     String?
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]
}

model Job {
  id          String    @id @default(cuid())
  employerId  String
  title       String
  description String
  city        String
  category    String
  jobType     String    @default("Doly iş wagty")
  salaryMin   Int?
  salaryMax   Int?
  currency    String    @default("TMT")
  phone       String?
  whatsapp    String?
  featured    Boolean   @default(false)
  status      JobStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  employer Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
}
